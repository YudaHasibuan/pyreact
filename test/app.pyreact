# My PyReact Database & Shared State App
# Generated by: pyreact new

shared_state {
    global_counter = 100
    theme          = "dark"
}

server {

    import json
    import random

    # ── Database Model ──
    class DbTask(db.Model):
        id = db.Column(db.Integer, primary_key=True)
        task = db.Column(db.String(100), nullable=False)
        priority = db.Column(db.String(20), default="Medium")
        status = db.Column(db.String(20), default="Pending")

    # AI Quotes pool
    QUOTES = [
        "Focus on being productive instead of busy.",
        "Your mind is for having ideas, not holding them.",
        "Simplicity is the soul of efficiency.",
        "The best way to predict the future is to create it.",
        "Done is better than perfect."
    ]

    def get_quote(name):
        quote = random.choice(QUOTES)
        return {"message": f"Hello, {name}! Today's AI quote: \"{quote}\""}

    def add_db_task(task_title, priority):
        new_item = DbTask(task=task_title, priority=priority, status="Pending")
        db.session.add(new_item)
        db.session.commit()
        return {"id": new_item.id, "task": new_item.task, "priority": new_item.priority, "status": new_item.status}

    def list_db_tasks():
        all_items = DbTask.query.all()
        if not all_items:
            t1 = DbTask(task="Learn PyReact MVP", priority="High", status="In Progress")
            t2 = DbTask(task="Build AI backend function", priority="Medium", status="Completed")
            t3 = DbTask(task="Design Tailwind frontend", priority="High", status="Pending")
            db.session.add(t1)
            db.session.add(t2)
            db.session.add(t3)
            db.session.commit()
            all_items = [t1, t2, t3]
        return [{"id": t.id, "task": t.task, "priority": t.priority, "status": t.status} for t in all_items]

    def get_analytics():
        return [
            {"label": "Mon", "value": 12},
            {"label": "Tue", "value": 19},
            {"label": "Wed", "value": 8},
            {"label": "Thu", "value": 15},
            {"label": "Fri", "value": 22},
            {"label": "Sat", "value": 9},
            {"label": "Sun", "value": 14}
        ]

    def classify_task(task_text):
        has_model = "classifier_model" in globals()
        return {
            "task": task_text,
            "category": "AI / Automation" if "ai" in task_text.lower() else "General Task",
            "model_loaded": has_model
        }

}

component StateViewer():
    return (
        <UI.Card title="Shared State Monitor (Sibling Component)">
            <UI.Text color="gray-400" className="mb-2">
                This component runs in a completely separate component file but subscribes to the same shared state store!
            </UI.Text>
            <UI.Text size="lg">
                Counter Value: <strong className="text-blue-400">{shared.global_counter}</strong>
            </UI.Text>
        </UI.Card>
    )

component Home():

    quote, setQuote = use_state(None)
    name, setName = use_state("")
    tasks, setTasks = use_state([])
    loading, setLoading = use_state(False)
    analytics, setAnalytics = use_state([])
    classified, setClassified = use_state(None)
    newTask, setNewTask = use_state("")
    taskPriority, setTaskPriority = use_state("Medium")

    def fetchQuote():
        setLoading(True)
        result = server.get_quote(name)
        setQuote(result)
        setLoading(False)

    def loadTasks():
        result = server.list_db_tasks()
        setTasks(result)
        chart_data = server.get_analytics()
        setAnalytics(chart_data)

    def runClassification():
        res = server.classify_task(newTask)
        setClassified(res)

    def addNewTask():
        if newTask:
            res = server.add_db_task(newTask, taskPriority)
            updated = server.list_db_tasks()
            setTasks(updated)
            setNewTask("")

    def incrementSharedCounter():
        setShared({"global_counter": shared.global_counter + 1})

    return (
        <UI.Page>
            <UI.Navbar title="PyReact AI Task Planner" />
            <div className="pt-24 max-w-6xl mx-auto px-4 pb-16">
                <div className="text-center mb-10">
                    <UI.Heading>AI Task & Goal Planner</UI.Heading>
                    <UI.Text color="gray-400" className="mt-2">
                        Combine Flask backend algorithms, SQLite database storage, and React user interfaces effortlessly.
                    </UI.Text>
                </div>

                <div className="grid md:grid-cols-3 gap-6">
                    {/* Column 1: Quotes */}
                    <UI.Card title="Get Inspired">
                        <UI.Input
                            label="Your Name"
                            value={name}
                            onChange={setName}
                            placeholder="Enter your name..."
                        />
                        <div className="mt-4">
                            <UI.Button onClick={fetchQuote} loading={loading} disabled={!name}>
                                Generate Quote
                            </UI.Button>
                        </div>
                        {quote && (
                            <UI.Alert type="success" className="mt-4">
                                {quote.message}
                            </UI.Alert>
                        )}
                    </UI.Card>

                    {/* Column 2: Add Database Task */}
                    <UI.Card title="Add Persistent Task">
                        <UI.Input
                            label="Task Description"
                            value={newTask}
                            onChange={setNewTask}
                            placeholder="e.g. Write an AI backend route..."
                        />
                        <div className="mt-2">
                            <UI.Input
                                label="Priority (High/Medium/Low)"
                                value={taskPriority}
                                onChange={setTaskPriority}
                                placeholder="Medium"
                            />
                        </div>
                        <div className="mt-4 flex gap-2">
                            <UI.Button onClick={addNewTask} variant="primary" disabled={!newTask}>
                                Save Task
                            </UI.Button>
                            <UI.Button onClick={runClassification} variant="secondary" disabled={!newTask}>
                                Classify AI
                            </UI.Button>
                        </div>
                        {classified && (
                            <div className="mt-4 p-3 bg-white/5 rounded-xl border border-white/10">
                                <UI.Text size="sm">Category: <strong>{classified.category}</strong></UI.Text>
                                <UI.Text size="xs" color="gray-400" className="mt-1">
                                    Model bound: {classified.model_loaded ? "Yes" : "No (Mock mode)"}
                                </UI.Text>
                            </div>
                        )}
                    </UI.Card>

                    {/* Column 3: Workspace State */}
                    <UI.Card title="Global Shared State">
                        <UI.Text color="gray-400" className="mb-4">
                            Counter: <strong className="text-xl text-blue-400">{shared.global_counter}</strong>
                        </UI.Text>
                        <div className="flex gap-2">
                            <UI.Button onClick={incrementSharedCounter} variant="primary">
                                Increment Global State
                            </UI.Button>
                            <UI.Button onClick={loadTasks} variant="secondary">
                                Load DB Data
                            </UI.Button>
                        </div>
                    </UI.Card>
                </div>

                {/* Sibling Viewers */}
                <div className="mt-8">
                    <StateViewer />
                </div>

                {/* Bottom Panels for Charts & Data */}
                {tasks.length > 0 && (
                    <div className="mt-8 grid md:grid-cols-2 gap-6">
                        <UI.Card title="Task Analytics (Weekly Activity)">
                            <div className="space-y-4">
                                <UI.Text size="sm" color="gray-400">Activity Bar Chart:</UI.Text>
                                <UI.Chart type="bar" data={analytics} height={180} />
                                <UI.Text size="sm" color="gray-400">Activity Line Chart:</UI.Text>
                                <UI.Chart type="line" data={analytics} height={180} />
                            </div>
                        </UI.Card>

                        <UI.Card title="Current Task List (SQLite)">
                            <UI.Table
                                columns={["id", "task", "priority", "status"]}
                                rows={tasks}
                            />
                        </UI.Card>
                    </div>
                )}
            </div>
        </UI.Page>
    )

style {
    primary    = "#6366f1"
    secondary  = "#4f46e5"
    background = "#090d16"
    surface    = "#111827"
    radius     = "12px"
    font       = "Outfit"
}

model Classifier {
    source = "model.pt"
    kind   = "pytorch"
}

database {
    provider = "sqlite"
    url      = "tasks.db"
}

dependencies {
    pip = ["requests"]
    npm = ["canvas-confetti@^1.9.3"]
}
